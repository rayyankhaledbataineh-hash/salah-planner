# Salah Planner configuration. Copy to `.env` for local runs.
# In the cloud these are set via Secret Manager (the GOOGLE_* values) and
# --set-env-vars (location), NOT from this file.

# --- OAuth credentials (CLOUD ONLY) ---
# Locally these come from credentials.json + token.json instead, so you can
# leave them blank for local development.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- File paths (LOCAL ONLY) ---
# Override where the OAuth files live. Defaults shown.
# GOOGLE_CREDENTIALS_PATH=./credentials.json
# GOOGLE_TOKEN_PATH=./token.json

# --- Location ---
# REQUIRED in the cloud: IP geolocation there returns Google's data-center IP,
# not yours. Set fixed coordinates + timezone. Locally these are optional
# (falls back to IP geolocation) but useful behind a VPN.
# Example below is Houston, TX.
LATITUDE=29.7604
LONGITUDE=-95.3698
TIMEZONE=America/Chicago

# --- Scheduling ---
# How many days ahead to keep prayer events topped up.
DAYS_AHEAD=3
